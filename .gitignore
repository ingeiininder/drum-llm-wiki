# ============================================================
# Groove Hub - .gitignore
# Strategy: Track wiki + pipeline + OCR output text.
# Only exclude large binary image files (data/input/).
# This allows full pipeline continuity across machines.
# ============================================================

# --- Raw Image Files (Large Binaries, DO NOT TRACK) ---
# Source images are large and can be re-scanned if needed.
data/input/
data/test_input/
data/test_output/

# data/output/ is intentionally TRACKED:
# - Contains 1,444 lightweight .txt OCR files (~2MB total)
# - Contains .processed_sources.log (pipeline state)
# - Required for cross-machine wiki expansion continuity

# --- Python Artifacts ---
__pycache__/
*.py[cod]
*.pyd
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/

# --- Environment & Secrets ---
.env
.env.local
.env.*.local
*.key

# --- OS & Editor ---
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/settings.json

# --- Obsidian Workspace State ---
# Keep .obsidian/ for vault config (themes, plugins), but ignore workspace cache
wiki/.obsidian/workspace.json
wiki/.obsidian/workspace-mobile.json
wiki/.obsidian/cache
